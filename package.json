{
  "name": "vue-laporan-keuangan-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --cwd frontend run dev",
